# =============================================================================
# Tune Server (Rust) — Environment Configuration
# Copy this file to .env and adjust values for your setup.
# The server loads .env automatically from the working directory.
# On Windows, it also checks %LOCALAPPDATA%\TuneServer\.env and
# the directory containing tune-server.exe.
# =============================================================================

# --- Library ---
# Comma-separated or JSON array of music directories to scan
# TUNE_MUSIC_DIRS=/music,/data/flac
# TUNE_MUSIC_DIRS=["/music", "/data/flac"]

# --- Server ---
TUNE_PORT=8888

# --- Database ---
# TUNE_DB_PATH=tune.db

# --- Logging ---
# TUNE_LOG_LEVEL=info

# --- Auto-scan on startup ---
# TUNE_AUTO_SCAN=true

# =============================================================================
# METADATA ENRICHMENT
# =============================================================================

# --- Discogs (FREE) ---
# Artist images and album metadata.
# Get your token at: https://www.discogs.com/settings/developers
# TUNE_DISCOGS_TOKEN=your_discogs_token_here

# --- Last.fm (FREE) ---
# TUNE_LASTFM_API_KEY=
# TUNE_LASTFM_API_SECRET=

# =============================================================================
# STREAMING SERVICES
# =============================================================================

# --- Tidal (OAuth, log in from web UI) ---
# TUNE_TIDAL_ENABLED=false

# --- Qobuz ---
# TUNE_QOBUZ_ENABLED=false

# --- Deezer (requires ARL cookie from deezer.com) ---
# TUNE_DEEZER_ENABLED=false
# TUNE_DEEZER_ARL=

# --- Spotify ---
# TUNE_SPOTIFY_ENABLED=false
# TUNE_SPOTIFY_CLIENT_ID=

# --- YouTube ---
# TUNE_YOUTUBE_ENABLED=false

# =============================================================================
# AUDIO
# =============================================================================

# Output format for DLNA: flac, wav, pcm
# TUNE_DEFAULT_OUTPUT_FORMAT=flac

# Windows audio backend: auto, wasapi, asio
# TUNE_LOCAL_AUDIO_BACKEND=auto

# Exclusive/bit-perfect mode (WASAPI exclusive, CoreAudio hog)
# TUNE_LOCAL_EXCLUSIVE_MODE=false

# =============================================================================
# NETWORK & DISCOVERY
# =============================================================================

# Override advertised IP (useful behind VPN or multi-NIC)
# TUNE_ADVERTISED_IP=192.168.1.100
