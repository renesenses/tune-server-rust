## Tune Server — Environment Configuration
## Copy this file to .env.tune and edit to match your setup.

## Path to your music library on the host
TUNE_MUSIC_PATH=/path/to/your/music

## Port (default 8888)
TUNE_PORT=8888

## Database path inside the container (no need to change)
TUNE_DB_PATH=/data/tune_v2.db

## Log level: error, warn, info, debug, trace
TUNE_LOG_LEVEL=info

## Auto-scan library on startup
TUNE_AUTO_SCAN=true

## Music directories inside the container (JSON array)
TUNE_MUSIC_DIRS=["/music"]
