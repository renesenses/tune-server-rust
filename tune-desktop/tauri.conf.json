{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tune",
  "version": "0.8.176",
  "identifier": "fr.mozaiklabs.tune-desktop",
  "build": {
    "frontendDist": "../web"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Tune",
        "url": "http://localhost:8888",
        "dragDropEnabled": false,
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  },
  "plugins": {}
}
