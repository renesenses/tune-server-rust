# Tune Server Configuration
# Copy to tune.toml and adjust as needed.
# Environment variables override these values (TUNE_PORT, TUNE_DB_PATH, etc.)

port = 8085
db_path = "tune.db"
web_dir = "web"
artwork_dir = "artwork_cache"
auto_scan = false
log_level = "info"

# Music directories to scan
music_dirs = [
    # "/path/to/music",
    # "/mnt/nas/music",
]

# Qobuz credentials (optional)
# qobuz_app_id = ""
# qobuz_app_secret = ""

# Audio backend on Windows: "auto", "wasapi", or "asio"
# local_audio_backend = "auto"

# DLNA play delay (ms) — for slow renderers (Atoll, Micromega, Wiim)
# that need a pause between SetAVTransportURI and Play
# dlna_play_delay_ms = 0

# Per-device delays (pattern matched against device name, case-insensitive)
# [device_delays]
# atoll = 2000
# micromega = 1500
# wiim = 500
